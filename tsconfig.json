{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "firefox-webext-browser"
    ]
  },
  "include": [
    "src/**/*.ts",
    "extension/src/**/*.ts"
  ]
}
