{
  "manifest_version": 3,
  "name": "Ground News Lookup (Minimal)",
  "version": "0.1.0",
  "description": "Look up the active tab on Ground News (no page injection).",
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://extension.ground.news/*",
    "https://production.checkitt.news/*",
    "https://groundnews.b-cdn.net/*"
  ],
  "action": {
    "default_title": "Ground News lookup",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg"
    }
  },
  "sidebar_action": {
    "default_title": "Ground News",
    "default_panel": "sidebar.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ground-news-lookup-minimal@nickmarcha.github",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["browsingActivity"]
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; object-src 'none'; upgrade-insecure-requests; connect-src https://extension.ground.news https://production.checkitt.news; img-src 'self' https://groundnews.b-cdn.net https: data:; style-src 'self' 'unsafe-inline'"
  }
}
